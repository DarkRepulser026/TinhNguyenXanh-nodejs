generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  Organizer
  Volunteer
}

enum DonationStatus {
  Pending
  Success
  Failed
}

enum ModerationStatus {
  Pending
  Approved
  Rejected
}

model AppUser {
  id                   String               @id @default(auto()) @map("_id") @db.ObjectId
  email                String               @unique
  passwordHash         String
  fullName             String
  phone                String?
  role                 UserRole             @default(Volunteer)
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization?
  volunteerProfile     Volunteer?
  eventComments        EventComment[]
  organizationReviews  OrganizationReview[]
  reportedEventReports EventReport[]        @relation("EventReportsReporter")
  reviewedEventReports EventReport[]        @relation("EventReportsReviewer")
}

model EventCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Organization {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  description      String?
  city             String?
  district         String?
  address          String?
  contactEmail     String?
  phoneNumber      String?
  website          String?
  organizationType String?
  memberCount      Int                  @default(0)
  eventsOrganized  Int                  @default(0)
  averageRating    Float                @default(0)
  totalReviews     Int                  @default(0)
  verified         Boolean              @default(false)
  ownerUserId      String?              @unique @db.ObjectId
  owner            AppUser?             @relation(fields: [ownerUserId], references: [id])
  events           Event[]
  reviews          OrganizationReview[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Event {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  status         String              @default("draft")
  maxVolunteers  Int                 @default(0)
  images         String?
  isHidden       Boolean             @default(false)
  organizationId String?             @db.ObjectId
  categoryId     String?             @db.ObjectId
  organization   Organization?       @relation(fields: [organizationId], references: [id])
  category       EventCategory?      @relation(fields: [categoryId], references: [id])
  registrations  EventRegistration[]
  favorites      EventFavorite[]
  comments       EventComment[]
  reports        EventReport[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Volunteer {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  userId        String              @unique @db.ObjectId
  fullName      String
  phone         String?
  user          AppUser             @relation(fields: [userId], references: [id])
  registrations EventRegistration[]
  favorites     EventFavorite[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model EventRegistration {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String    @db.ObjectId
  volunteerId  String    @db.ObjectId
  fullName     String
  phone        String?
  reason       String?
  status       String    @default("Pending")
  registeredAt DateTime  @default(now())
  event        Event     @relation(fields: [eventId], references: [id])
  volunteer    Volunteer @relation(fields: [volunteerId], references: [id])

  @@unique([eventId, volunteerId])
}

model EventFavorite {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String    @db.ObjectId
  volunteerId String    @db.ObjectId
  createdAt   DateTime  @default(now())
  event       Event     @relation(fields: [eventId], references: [id])
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@unique([eventId, volunteerId])
}

model Donation {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  donorName       String?
  amount          Float
  phoneNumber     String?
  message         String?
  transactionCode String         @unique
  paymentMethod   String         @default("momo")
  status          DonationStatus @default(Pending)
  providerRef     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model EventComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @db.ObjectId
  userId    String   @db.ObjectId
  content   String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id])
  user      AppUser  @relation(fields: [userId], references: [id])
}

model OrganizationReview {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String           @db.ObjectId
  userId         String           @db.ObjectId
  rating         Int
  title          String?
  content        String?
  status         ModerationStatus @default(Pending)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           AppUser          @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model EventReport {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  eventId          String           @db.ObjectId
  reporterUserId   String           @db.ObjectId
  reason           String
  details          String?
  status           ModerationStatus @default(Pending)
  reviewedByUserId String?          @db.ObjectId
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  event            Event            @relation(fields: [eventId], references: [id])
  reporterUser     AppUser          @relation("EventReportsReporter", fields: [reporterUserId], references: [id])
  reviewedByUser   AppUser?         @relation("EventReportsReviewer", fields: [reviewedByUserId], references: [id])
}
